# ==============================================================================
# 1. WordPress コアファイル
#    WPのコアファイルは公式からダウンロード・配置するためGit管理から除外
# ==============================================================================
wp-admin/
wp-includes/
license.txt
readme.html
xmlrpc.php
wp-config.php

# ==============================================================================
# 2. WordPress 関連の生成・アップロードファイル
#    ユーザーがアップロードするメディア、キャッシュ、ログファイルなど
# ==============================================================================
# アップロードされたメディアファイル
wp-content/uploads/

# キャッシュファイル（WP Super Cache, W3 Total Cacheなど）
wp-content/cache/

# マルチサイトの場合のアップロードディレクトリ
wp-content/blogs.dir/

# バックアップされたファイル
wp-content/backup/

# WordPressのアップグレード時に生成される一時ファイル
wp-content/upgrade/

# ==============================================================================
# 3. 環境設定ファイル・機密情報
#    データベース接続情報やAPIキーなど、環境ごとに異なる情報や機密情報
# ==============================================================================
# 環境変数を管理するファイル (Laravelなどでも利用)
.env
# ローカル開発環境固有の環境変数ファイル
.env.local

# ==============================================================================
# 5. パッケージマネージャー関連 (Composer, npm/Yarnなど)
#    依存関係ライブラリ本体やロックファイル（考慮が必要）
# ==============================================================================
# PHP の依存関係管理 (Composer)
vendor/

# Node.js の依存関係管理 (npm / Yarn)
node_modules/
# npmのデバッグログファイル
npm-debug.log*
# ★検討: npmのロックファイル。通常はGitに含めるべき。
package-lock.json
# ★検討: Yarnのロックファイル。通常はGitに含めるべき。
yarn.lock

# ==============================================================================
# 6. IDE/エディタ関連ファイル
#    開発環境（IDE、エディタ）が自動生成する一時ファイルや設定ファイル
# ==============================================================================
# VS Codeの設定ディレクトリ
.vscode/
# IntelliJ IDEA系の設定ディレクトリ
.idea/
# Sublime Textのプロジェクトファイル
*.sublime-project
# Sublime Textのワークスペースファイル
*.sublime-workspace
# Vimのスワップファイル
*.swp
# エディタが生成するバックアップファイル
*.bak
*~

# ==============================================================================
# 7. OS 関連ファイル
#    OSが自動生成する非表示ファイル
# ==============================================================================
# macOSのディレクトリ設定ファイル
.DS_Store
# Windowsのサムネイルキャッシュファイル
Thumbs.db
# Windowsのディレクトリカスタマイズファイル
desktop.ini

# ==============================================================================
# 8. ログファイル・一時ファイル・バックアップファイル
#    アプリケーションやサーバーが生成するログ、一時的なバックアップ
# ==============================================================================
# 全てのログファイル
*.log
# 全ての一時ファイル
*.tmp
*.temp
# 圧縮ファイル
*.zip
# tarアーカイブファイル
*.tar
*.tar.gz
# データベースダンプファイル（機密情報を含むため）
*.sql
# WordPressのデバッグログファイル
debug.log
# PHPのエラーログ
error_log
